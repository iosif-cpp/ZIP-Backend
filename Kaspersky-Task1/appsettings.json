{
  "ConnectionStrings": {
    "PostgresLogging": "Host=localhost;Port=5432;Database=serilog;Username=serilog;Password=serilog"
  },
  "Serilog": {
    "Postgres": {
      "TableName": "http_request_logs",
      "NeedAutoCreateTable": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Archive": {
    "FilesDir": "files",
    "ZipArchivesDir": "ZipArchives",
    "MaxFilesPerArchive": 1000
  },
  "AllowedHosts": "*"
}
